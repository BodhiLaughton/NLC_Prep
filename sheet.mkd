## HOW TO MAKE A CLASS
```cpp
class Runner {
    public:
        Runner(string name, int age, int bib, double registrationFee) {
            this->name = name;
            this->age = age;
            this->bib = bib;
            this->registrationFee = registrationFee;
        }

        string getName() {
            return name;
        }

        int getAge() {
            return age;
        }

        int getBib() {
            return bib;
        }

        double getRegistrationFee() {
            return registrationFee;
        }

        string getCategory() {
            if (age >= 51) {
                return "Senior";
            } else if (age >= 35) {
                return "Adult";
            } else {
                return "Young Adult";
            }
        }

    private:
        string name;
        int age;
        int bib;
        double registrationFee;
};
```


